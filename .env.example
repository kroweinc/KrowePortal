# KrowePortal environment — copy to .env.local for development and set the same
# keys in the production host (Vercel). Never commit real secrets.

# ── Required ────────────────────────────────────────────────────────────────
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only — never expose to the client

# OpenAI
OPENAI_API_KEY=

# GitHub OAuth — use separate OAuth Apps for dev and prod.
# Dev app callback:  http://localhost:3030/api/github/callback
# Prod app callback: https://krowehub.com/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional locally; required if not on Vercel production (which auto-derives the URL).
GITHUB_REDIRECT_URI=

# Public production origin. In Vercel production, set both to:
# https://krowehub.com
APP_ORIGIN=
NEXT_PUBLIC_APP_ORIGIN=

# Production proxy support. The portal is path-proxied behind the krowehub.com
# landing site (a separate Vercel project), so it must serve its own /_next
# chunks from its own origin to avoid colliding with the landing site's assets.
# In the PORTAL's Vercel production env, set this to its own production URL:
# https://krowe-portal.vercel.app
# (Leave blank only if the portal ever owns krowehub.com at the apex directly.)
NEXT_PUBLIC_ASSET_PREFIX=

# Secret encryption (GitHub tokens at rest). Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Email — Resend (https://resend.com)
# Auth mail (signup/reset/email-change) is sent by Supabase via Resend Custom SMTP;
# that key lives in the Supabase dashboard. Setup: docs/auth-email-resend-smtp.md
# The APP also sends product-feedback notifications directly via the Resend API,
# so it needs the key here too (Vercel env for prod, .env.local for dev):
RESEND_API_KEY=
# Recipient(s) for new-feedback notifications — comma-separated; defaults to
# kroweinc@gmail.com if unset.
FEEDBACK_NOTIFICATION_EMAIL=

# ── Optional / tuning ───────────────────────────────────────────────────────
OPENAI_MODEL=                       # defaults to gpt-5.4-mini
OPENAI_ENABLE_WEB_SEARCH=           # "true" to ground PRD research via web_search
AI_DAILY_TOKEN_CAP=                 # per-user rolling-24h token cap; unset = no cap
NEXT_DEV_ALLOWED_ORIGINS=           # dev only — extra allowed dev origins (LAN IP)

# ── Dev-only — DO NOT set in production ─────────────────────────────────────
# Both are gated by NODE_ENV !== "production", but never set them in the prod host.
# NEXT_PUBLIC_ENABLE_ROLE_SWITCHER=true   # shows the dev role switcher
# DEV_AUTH_ROLE=builder                   # synthetic dev identity (operator|builder)
