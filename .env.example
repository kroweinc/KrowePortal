# KrowePortal environment — copy to .env.local for development and set the same
# keys in the production host (Vercel). Never commit real secrets.

# ── Required ────────────────────────────────────────────────────────────────
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only — never expose to the client

# Google sign-in (ID-token flow via Google Identity Services).
# When set, the login page uses Google's "Sign in with Google" button directly
# and exchanges the ID token with Supabase (supabase.auth.signInWithIdToken),
# so Google's consent screen shows our own domain instead of the Supabase URL.
# Use the OAuth 2.0 *Web application* Client ID from Google Cloud Console, and
# add these Authorized JavaScript origins in Google Cloud Console:
#   https://krowehub.com
#   http://localhost:3030
#   http://localhost          ← required for FedCM/One Tap (Google's docs)
#   http://127.0.0.1:3030     ← if you browse via 127.0.0.1 instead of localhost
# Also add this same Client ID under Supabase → Authentication →
# Providers → Google → "Authorized Client IDs". Public value (safe to expose).
# Leave blank to fall back to the redirect OAuth flow (shows the Supabase URL).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# OpenAI
OPENAI_API_KEY=

# GitHub OAuth — use separate OAuth Apps for dev and prod.
# Dev app callback:  http://localhost:3030/api/github/callback
# Prod app callback: https://krowehub.com/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional locally; required if not on Vercel production (which auto-derives the URL).
GITHUB_REDIRECT_URI=

# Public production origin. Required in production: without it, OAuth
# redirects fall back to the incoming request's Host header, which a
# misconfigured proxy could let a caller influence. In Vercel production,
# set both to:
# https://krowehub.com
APP_ORIGIN=
NEXT_PUBLIC_APP_ORIGIN=

# Production proxy support. The portal is path-proxied behind the krowehub.com
# landing site (a separate Vercel project), so it must serve its own /_next
# chunks from its own origin to avoid colliding with the landing site's assets.
# In the PORTAL's Vercel production env, set this to its own production URL:
# https://krowe-portal.vercel.app
# (Leave blank only if the portal ever owns krowehub.com at the apex directly.)
NEXT_PUBLIC_ASSET_PREFIX=

# Secret encryption (GitHub + Granola OAuth tokens at rest). Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Granola OAuth (optional). The redirect URI normally resolves from
# APP_ORIGIN / the request origin; set this only to pin it explicitly:
# GRANOLA_REDIRECT_URI=https://your-host/api/granola/callback
# GRANOLA_TIMING=1  # log per-stage Granola import/extraction timings

# Email — Resend (https://resend.com)
# Auth mail (signup/reset/email-change) is sent by Supabase via Resend Custom SMTP;
# that key lives in the Supabase dashboard. Setup: docs/auth-email-resend-smtp.md
# The APP also sends product-feedback notifications directly via the Resend API,
# so it needs the key here too (Vercel env for prod, .env.local for dev):
RESEND_API_KEY=
# Recipient(s) for new-feedback notifications — comma-separated; defaults to
# kroweinc@gmail.com if unset.
FEEDBACK_NOTIFICATION_EMAIL=

# ── Optional / tuning ───────────────────────────────────────────────────────
OPENAI_MODEL=                       # defaults to gpt-5.4-mini
OPENAI_REASONING_EFFORT=            # minimal|low|medium|high — defaults to "low" (faster gen); "default" omits the param
OPENAI_ENABLE_WEB_SEARCH=           # "true" to ground PRD research via web_search
OPENAI_STRICT_SCHEMA=               # "false" to disable strict json_schema outputs (fall back to json_object); defaults on
OPENAI_ENABLE_STREAMING=            # "true" to stream PRD/quote generation via the SSE routes; defaults off (blocking path)
OPENAI_PRD_MAX_TOKENS=              # positive integer ceiling for PRD output tokens; blank = 32000 (generous — never omit: a reasoning model with no cap never terminates)
AI_DAILY_TOKEN_CAP=                 # per-user rolling-24h token cap; unset = no cap
AI_BURST_PER_MIN=                   # per-user AI generations/min burst limit; defaults to 10
RATE_LIMIT_SIGN_TOKEN_PER_MIN=      # public sign/decline attempts per token/min; defaults to 5
RATE_LIMIT_SIGN_IP_PER_MIN=         # public sign/decline attempts per IP/min; defaults to 10
RATE_LIMIT_RESUME_TOKEN_PER_MIN=    # public resume fetches per token/min; defaults to 20
NEXT_DEV_ALLOWED_ORIGINS=           # dev only — extra allowed dev origins (LAN IP)

# Demo/seed scripts only (scripts/seed-demo-account.mjs, scripts/capture-screens.mjs).
# Password for the seeded demo logins (investinkrowe@ / krowe.internal@krowehub.com).
# Rotate the Supabase auth users if this value ever leaks; never hardcode it.
DEMO_ACCOUNT_PASSWORD=

# ── Dev-only — DO NOT set in production ─────────────────────────────────────
# Both are gated by NODE_ENV !== "production", but never set them in the prod host.
# NEXT_PUBLIC_ENABLE_ROLE_SWITCHER=true   # shows the dev role switcher
# DEV_AUTH_ROLE=builder                   # synthetic dev identity (operator|builder)
